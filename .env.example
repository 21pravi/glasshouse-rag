# ── Online engine ────────────────────────────────────────────────────────────
# Set ANY ONE of these to enable the online engine. If several are set, the
# first in this order wins. Leave all blank to run offline-only (no key needed).
#
# Free tiers: Groq and Gemini are generous and need no credit card.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# Optional: pin a specific model on whichever provider is selected.
# e.g. GLASSHOUSE_MODEL=llama-3.1-8b-instant
GLASSHOUSE_MODEL=

# ── Telegram front-end (bot.py) only ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Retrieval tuning ─────────────────────────────────────────────────────────
TOP_K=3
CHUNK_SIZE=500
CHUNK_OVERLAP=100
KNOWLEDGE_BASE_DIR=knowledge_base
SQLITE_DB_PATH=index.db
